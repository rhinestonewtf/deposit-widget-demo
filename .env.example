# Reown (WalletConnect) project ID used by the deposit modal for wallet connection.
NEXT_PUBLIC_REOWN_PROJECT_ID=

# Rhinestone API key (surfaced in the generated code snippet).
NEXT_PUBLIC_RHINESTONE_API_KEY=

# Internal-only. Set to "true" to expose the Swapped fiat on-ramp controls
# (Pay with Card / Apple Pay / Bank Transfer, Fund from Exchange, Transfer Crypto
# QR) in the Behaviour tab. Off by default so the public demo is unchanged.
# This is a build-time NEXT_PUBLIC_ flag — set it in the build/deploy environment
# of the internal preview, not just at runtime.
NEXT_PUBLIC_ENABLE_FIAT_ONRAMP=false
